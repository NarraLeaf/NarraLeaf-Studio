{
  "manifestVersion": 2,
  "id": "narraleaf.gallery",
  "name": "Gallery",
  "version": "1.2.0",
  "description": "Manage visual novel gallery artworks and their variants, and unlock them from blueprint graphs.",
  "publisher": "NarraLeaf Studio",
  "entries": {
    "studio": "main.js",
    "runtime": "runtime.js"
  },
  "contributes": {
    "blueprintNodes": [
      "narraleaf.gallery.add",
      "narraleaf.gallery.remove",
      "narraleaf.gallery.clear",
      "narraleaf.gallery.isUnlocked",
      "narraleaf.gallery.getVariantCount",
      "narraleaf.gallery.getVariant",
      "narraleaf.gallery.getCover",
      "narraleaf.gallery.getArtworkCount",
      "narraleaf.gallery.getArtworkAt"
    ],
    "runtimeData": [
      "narraleaf.gallery.items"
    ]
  },
  "permissions": []
}
